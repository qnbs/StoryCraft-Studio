{
  "name": "storycraft-studio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "npm@10.x",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "typecheck": "tsc --noEmit",
    "lhci:assert": "lhci autorun --upload.target=temporary-public-storage",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "prepare": "husky",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "node -e \"if (process.env.CI !== 'true') { console.error('E2E tests are CI-only. Set CI=true or run via GitHub Actions.'); process.exit(1); }\" && playwright test",
    "test:e2e:ui": "node -e \"if (process.env.CI !== 'true') { console.error('E2E tests are CI-only. Set CI=true or run via GitHub Actions.'); process.exit(1); }\" && playwright test --ui",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "dev:tauri": "tauri dev",
    "deploy:gh-pages": "npm run build && npx gh-pages -d dist"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.10.0",
    "@reduxjs/toolkit": "^2.2.6",
    "@tailwindcss/postcss": "^4.2.1",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "autoprefixer": "^10.4.27",
    "docx": "^8.5.0",
    "epub-gen": "^0.1.0",
    "jspdf": "^2.5.1",
    "jszip": "^3.10.1",
    "konva": "^10.2.0",
    "leaflet": "^1.9.4",
    "lz-string": "^1.5.0",
    "mammoth": "^1.11.0",
    "postcss": "^8.5.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-flow": "^1.0.3",
    "react-force-graph-2d": "^1.29.1",
    "react-hotkeys-hook": "^5.2.4",
    "react-konva": "^19.2.3",
    "react-leaflet": "^5.0.0",
    "react-redux": "^9.1.2",
    "react-router-dom": "^7.9.6",
    "recharts": "^3.7.0",
    "redux-undo": "^1.1.0",
    "tailwindcss": "^4.2.1",
    "uuid": "^13.0.0",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/epub-gen": "^0.1.2",
    "@types/lz-string": "^1.3.34",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "storybook": "^8.6.18",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18",
    "@lhci/cli": "^0.15.1",
    "wait-on": "^7.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
