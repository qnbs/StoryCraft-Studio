{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "prHourlyLimit": 5,
  "prConcurrentLimit": 10,
  "packageRules": [
    {
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "matchPackagePatterns": [
        "^react",
        "^vite",
        "^tailwind",
        "^storybook",
        "^@storybook",
        "^@vitejs",
        "^@tauri-apps"
      ],
      "rangeStrategy": "bump",
      "automerge": false
    },
    {
      "groupName": "react-vite-storybook majors",
      "matchPackagePatterns": ["^react", "^vite", "^@vitejs", "^storybook", "^@storybook"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["major-update"]
    }
  ]
}
