# ─── StoryCraft Studio — Dev Container Environment Variables ──────────────────
# QNBS-v3: Copy this file to .env and fill in values for local dev.
# These vars are passed to the container via devcontainer.json containerEnv.
# NEVER commit real API keys — use the in-app settings UI instead.
# ──────────────────────────────────────────────────────────────────────────────

# ── Vite ──────────────────────────────────────────────────────────────────────
# Base URL path for the app (default: "/" in dev container, "/StoryCraft-Studio/" for GitHub Pages)
VITE_BASE=/

# ── Node.js ───────────────────────────────────────────────────────────────────
# Memory limit for Node.js (Vite + TypeScript server need headroom)
NODE_OPTIONS=--max-old-space-size=6144

# ── Playwright ────────────────────────────────────────────────────────────────
# Set CI=true to enable Playwright E2E tests (required by package.json scripts)
CI=true

# ── Playwright browser cache ──────────────────────────────────────────────────
# Matches the Dockerfile pre-install location
PLAYWRIGHT_BROWSERS_PATH=/usr/local/playwright

# ── Deploy target (optional) ──────────────────────────────────────────────────
# Set to "edge" for Vercel/Cloudflare builds, leave empty for GitHub Pages
# DEPLOY_TARGET=edge

# ── Lighthouse (optional) ─────────────────────────────────────────────────────
# LHCI token for CI uploads (only needed in CI, not in dev container)
# LHCI_GITHUB_APP_TOKEN=
