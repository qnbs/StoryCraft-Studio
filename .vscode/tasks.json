{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Graphify: install integrations",
      "type": "npm",
      "script": "graphify:install",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" },
      "group": "none"
    },
    {
      "label": "Graphify: update graph (AST)",
      "type": "npm",
      "script": "graphify:update",
      "problemMatcher": [],
      "presentation": { "reveal": "silent", "panel": "shared" },
      "group": { "kind": "build", "isDefault": false }
    },
    {
      "label": "Graphify: hook status",
      "type": "npm",
      "script": "graphify:status",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" },
      "group": "none"
    },
    {
      "label": "Graphify: install git hooks",
      "type": "npm",
      "script": "graphify:hooks",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" },
      "group": "none"
    },
    {
      "label": "CodeGraph: status",
      "type": "npm",
      "script": "codegraph:status",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" },
      "group": "none"
    },
    {
      "label": "CodeGraph: update index",
      "type": "npm",
      "script": "codegraph:update",
      "problemMatcher": [],
      "presentation": { "reveal": "silent", "panel": "shared" },
      "group": { "kind": "build", "isDefault": false }
    },
    {
      "label": "CodeGraph: generate report",
      "type": "npm",
      "script": "codegraph:report",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" },
      "group": "none"
    },
    {
      "label": "Dual-Graph: update both",
      "type": "npm",
      "script": "graphs:update",
      "problemMatcher": [],
      "presentation": { "reveal": "silent", "panel": "shared" },
      "group": { "kind": "build", "isDefault": false }
    },
    {
      "label": "CI Analyzer: Fetch and Analyze Failed Run",
      "type": "shell",
      "command": "python3",
      "args": [
        "scripts/ci-analyzer/analyzer.py",
        "--vitest-json",
        "${workspaceFolder}/artifacts/vitest-results-node22/test-results.json",
        "--stryker-json",
        "${workspaceFolder}/artifacts/stryker-report-json/mutation.json",
        "--logs",
        "${workspaceFolder}/artifacts/ci-logs.txt",
        "--output",
        "vscode"
      ],
      "problemMatcher": {
        "owner": "ai-analyzer",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": [
          {
            "regexp": "^AI-ANALYSIS: ([^:]+):(\\d+):(\\d+) (\\w+): (.+) Fix: (.+)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "severity": 4,
            "message": 5,
            "code": 6
          }
        ]
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "group": "build",
      "isBackground": false,
      "options": {
        "env": {
          "OPENROUTER_API_KEY": "${env:OPENROUTER_API_KEY}",
          "GITHUB_TOKEN": "${env:GITHUB_TOKEN}"
        }
      }
    },
    {
      "label": "CI Analyzer: Watch for Failed Runs",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "while true; do RUN_ID=$(gh run list --status failure --limit 1 --json databaseId --jq '.[0].databaseId' 2>/dev/null); if [ -n \"$RUN_ID\" ]; then echo \"AI-ANALYSIS: CI run $RUN_ID failed - triggering analysis\"; gh run download \"$RUN_ID\" -n vitest-results-node22 --dir artifacts 2>/dev/null || true; gh run download \"$RUN_ID\" -n stryker-report-json --dir artifacts 2>/dev/null || true; gh run view \"$RUN_ID\" --log-failed > artifacts/ci-logs.txt 2>/dev/null || true; python3 scripts/ci-analyzer/analyzer.py --vitest-json artifacts/vitest-results-node22/test-results.json --logs artifacts/ci-logs.txt --output vscode; fi; sleep 30; done"
      ],
      "problemMatcher": {
        "owner": "ai-analyzer",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": [
          {
            "regexp": "^AI-ANALYSIS: ([^:]+):(\\d+):(\\d+) (\\w+): (.+) Fix: (.+)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "severity": 4,
            "message": 5,
            "code": 6
          }
        ]
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "group": "build",
      "isBackground": true,
      "runOptions": {
        "runOn": "folderOpen"
      },
      "options": {
        "env": {
          "OPENROUTER_API_KEY": "${env:OPENROUTER_API_KEY}",
          "GITHUB_TOKEN": "${env:GITHUB_TOKEN}"
        }
      }
    }
  ]
}
